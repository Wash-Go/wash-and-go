# Admin dashboard (Next.js). Only NEXT_PUBLIC_* vars — they ship in the client
# bundle, so nothing secret goes here (Firebase web config is committed in
# lib/firebaseConfig.ts, public by design).

# API base URL. REQUIRED in production — unset silently falls back to localhost.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Dev-only auth stub: sets x-dev-uid instead of a real Firebase login, and only
# works against an API with AUTH_DEV_BYPASS=1. Defaults to "dev-admin" in dev.
# MUST be unset in production so real Firebase admin login is required.
# NEXT_PUBLIC_DEV_UID=dev-admin
