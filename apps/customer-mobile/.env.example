# Customer app (Expo/React Native). Only EXPO_PUBLIC_* vars are exposed to the
# app bundle — nothing secret. Firebase web config is committed (public).

# API base URL the app calls. REQUIRED in a production build.
EXPO_PUBLIC_API_URL=http://localhost:4000

# Dev-only auth stub (x-dev-uid, needs API AUTH_DEV_BYPASS=1). Defaults to
# "dev-customer" in __DEV__. MUST be unset in a production build (real Firebase
# phone login required).
# EXPO_PUBLIC_DEV_UID=dev-customer
