// Weekend-MVP subset of the full PLAN.md §2 schema.
// Full schema (zones, runs, schedules, credits, remittance batches, handoffs)
// lands with its phases — do not add tables the current phase doesn't use.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  RIDER
  SHOP_OWNER
  SHOP_STAFF
  ADMIN
}

enum ServiceType {
  SCHEDULED
  EXPRESS
}

enum OrderStatus {
  BOOKED
  ASSIGNED
  PICKED_UP
  AT_SHOP
  PROCESSING
  READY_FOR_RETURN
  OUT_FOR_RETURN
  DELIVERED
  CANCELLED
}

enum BillingUnit {
  PER_KG
  PER_PIECE
  FLAT
}

model User {
  id          String    @id @default(cuid())
  firebaseUid String    @unique
  phone       String    @unique
  displayName String
  roles       UserRole[]
  createdAt   DateTime  @default(now())
  disabledAt  DateTime?

  orders          Order[]      @relation("CustomerOrders")
  assignedOrders  Order[]      @relation("RiderOrders")
  shopMemberships ShopMember[]
  orderEvents     OrderEvent[]
  addresses       Address[]
}

// Customer address book — saved pickup points the app prefills at booking. The
// Order still snapshots its own pickupAddress/lat/lng at create (denormalized),
// so deleting an address never mutates a past order. At most one default/user.
model Address {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  label     String? // "Home", "Office"
  line      String // street / barangay free text
  lat       Decimal? @db.Decimal(9, 6)
  lng       Decimal? @db.Decimal(9, 6)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Shop {
  id                 String   @id @default(cuid())
  name               String
  address            String
  lat                Decimal  @db.Decimal(9, 6)
  lng                Decimal  @db.Decimal(9, 6)
  active             Boolean  @default(true)
  // PENDING founder rate card — 12% is the planning assumption
  commissionPct      Decimal  @default(12.00) @db.Decimal(5, 2)
  // Reserved express queue capacity (Logistics v1.1). Count check runs inside
  // the dispatch tx with a pg advisory lock keyed (shopId, Asia/Manila date).
  expressSlotsPerDay Int      @default(0)
  createdAt          DateTime @default(now())

  members  ShopMember[]
  services ShopService[]
  orders   Order[]
}

model ShopMember {
  id     String @id @default(cuid())
  shopId String
  userId String
  role   String // "OWNER" | "STAFF"
  shop   Shop   @relation(fields: [shopId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([shopId, userId])
}

model ServiceCatalogItem {
  id          String        @id @default(cuid())
  code        String        @unique // "WDF", "WDF_IRON", "DRY_CLEAN"
  name        String
  billingUnit BillingUnit
  shopPrices  ShopService[]
}

model ShopService {
  id              String             @id @default(cuid())
  shopId          String
  serviceId       String
  ratePhp         Decimal            @db.Decimal(10, 2)
  turnaroundHours Int
  active          Boolean            @default(true)
  shop            Shop               @relation(fields: [shopId], references: [id])
  service         ServiceCatalogItem @relation(fields: [serviceId], references: [id])
  orders          Order[]

  @@unique([shopId, serviceId])
}

model Order {
  id          String      @id @default(cuid())
  code        String      @unique // "WG-2026-000001" via global sequence
  customerId  String
  customer    User        @relation("CustomerOrders", fields: [customerId], references: [id])
  serviceType ServiceType
  status      OrderStatus @default(BOOKED)

  // MVP: free-text address + hardcoded coverage check. Zones land with the
  // scheduled engine (maps vendor D10 still open).
  pickupAddress String
  pickupLat     Decimal? @db.Decimal(9, 6)
  pickupLng     Decimal? @db.Decimal(9, 6)

  shopId        String?
  shop          Shop?        @relation(fields: [shopId], references: [id])
  shopServiceId String?
  shopService   ShopService? @relation(fields: [shopServiceId], references: [id])

  // Manual dispatch at MVP: ops assigns a rider user in the portal.
  assignedRiderId String?
  assignedRider   User?   @relation("RiderOrders", fields: [assignedRiderId], references: [id])

  weightEstimateKg Decimal? @db.Decimal(6, 2)
  weightKg         Decimal? @db.Decimal(6, 2) // set at weigh-in; triggers price recompute

  // Price breakdown — computed by the pricing engine, never by clients.
  washValuePhp      Decimal @default(0) @db.Decimal(10, 2)
  deliveryFeePhp    Decimal @default(0) @db.Decimal(10, 2)
  serviceFeePhp     Decimal @default(0) @db.Decimal(10, 2)
  commissionPhp     Decimal @default(0) @db.Decimal(10, 2)
  shopRemittancePhp Decimal @default(0) @db.Decimal(10, 2)
  customerTotalPhp  Decimal @default(0) @db.Decimal(10, 2)

  // MVP: cash recorded manually. PayMongo lands Phase 2.
  paidCashAt DateTime?

  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  events         OrderEvent[]
  remittanceLine RemittanceLine?

  @@index([status, createdAt])
  @@index([shopId, status])
  @@index([customerId, createdAt(sort: Desc)])
}

model OrderEvent {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id])
  status      OrderStatus
  actorUserId String?
  actor       User?       @relation(fields: [actorUserId], references: [id])
  meta        Json?
  createdAt   DateTime    @default(now())

  @@index([orderId, createdAt])
}

// One row per DELIVERED order — idempotent via unique(orderId).
// Batching + payouts land Phase 4.
model RemittanceLine {
  id             String           @id @default(cuid())
  orderId        String           @unique
  order          Order            @relation(fields: [orderId], references: [id])
  shopId         String
  washValuePhp   Decimal          @db.Decimal(10, 2)
  commissionPhp  Decimal          @db.Decimal(10, 2)
  payoutPhp      Decimal          @db.Decimal(10, 2)
  batchId        String?
  batch          RemittanceBatch? @relation(fields: [batchId], references: [id])
  createdAt      DateTime         @default(now())

  @@index([shopId, createdAt])
  @@index([batchId])
  // Fast lookup of still-unbatched lines for a shop when closing a period.
  @@index([shopId, batchId])
}

enum RemittanceStatus {
  PENDING // closed, payout owed to the shop, transfer not yet made
  PAID // ops recorded the external transfer (reference + paidAt set)
}

// A period's payout to one shop — the sum of its unbatched RemittanceLines in
// [periodStart, periodEnd). Payout transfer is external at launch; the batch
// tracks intent and an ops user marks it paid with the transfer reference.
model RemittanceBatch {
  id          String           @id @default(cuid())
  shopId      String
  periodStart DateTime
  periodEnd   DateTime
  totalPhp    Decimal          @db.Decimal(12, 2)
  lineCount   Int
  status      RemittanceStatus @default(PENDING)
  reference   String? // external transfer reference, set on mark-paid
  paidAt      DateTime?
  paidByUid   String?
  createdAt   DateTime         @default(now())
  lines       RemittanceLine[]

  @@index([shopId, createdAt])
  @@index([status])
}

// Platform-level business rules, admin-editable at runtime (no redeploy).
// Singleton (id = 1). Per-shop rates live on ShopService, NOT here.
// Placeholders (expressWeightThresholdKg, minOrderPricePhp, platformFeePhp) have
// no consumer yet — editable but inert until matching/floor/fee code lands.
model PlatformConfig {
  id                       Int      @id @default(1)
  serviceFeePhp            Decimal  @db.Decimal(10, 2)
  deliveryBasePhp          Decimal  @db.Decimal(10, 2)
  deliveryFreeKm           Decimal  @db.Decimal(6, 2)
  deliveryPerKmPhp         Decimal  @db.Decimal(10, 2)
  deliveryMaxPhp           Decimal  @db.Decimal(10, 2)
  deliveryRoadFactor       Decimal  @db.Decimal(5, 3)
  maxResolveKm             Decimal  @db.Decimal(6, 2)
  expressWeightThresholdKg Decimal  @db.Decimal(6, 2)
  minOrderPricePhp         Decimal  @db.Decimal(10, 2)
  platformFeePhp           Decimal  @db.Decimal(10, 2)
  updatedAt                DateTime @updatedAt
}

// Append-only audit of platform-config changes (one row per changed field).
model ConfigAudit {
  id        String   @id @default(cuid())
  actorUid  String
  field     String
  oldValue  String
  newValue  String
  changedAt DateTime @default(now())

  @@index([changedAt(sort: Desc)])
}
