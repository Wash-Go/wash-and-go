# development | test | production. Required. In production, AUTH_DEV_BYPASS must
# be 0 — the app refuses to boot with the bypass on outside development/test.
NODE_ENV=development
DATABASE_URL="postgresql://dev:dev@localhost:5433/wash_and_go"
REDIS_URL="redis://localhost:6380"
# Firebase Admin SDK — path to service account JSON (never commit the JSON itself)
GOOGLE_APPLICATION_CREDENTIALS="./firebase-service-account.json"
PORT=4000
# Dev-only auth shim: trust x-dev-uid instead of a real Firebase token. MUST be 0
# in production/staging (fail-safe refuses boot otherwise).
AUTH_DEV_BYPASS=0
# CORS allow-list, comma-separated. Unset in prod = no cross-origin; unset in dev
# reflects the request origin.
# CORS_ORIGINS="https://admin.washandgo.app,https://portal.washandgo.app"
