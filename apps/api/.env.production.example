# Production env for the API (Railway). Set these in the Railway service, NOT a
# committed file. NODE_ENV=production makes the auth fail-safe active, so
# AUTH_DEV_BYPASS MUST be 0 (the app refuses to boot otherwise).

NODE_ENV=production
# Railway injects PORT; the app reads it. Leave unset or let Railway set it.
# PORT=4000

# Railway Postgres plugin provides this. Add ?connection_limit=… if pooling.
DATABASE_URL=postgresql://user:pass@host:5432/railway

# Real auth only in prod — no x-dev-uid.
AUTH_DEV_BYPASS=0

# Firebase Admin — paste the service-account JSON as ONE env var (no file needed).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"wash-and-go-28cce", "...": "..."}

# Maps.
MAPS_PROVIDER=tomtom
TOMTOM_API_KEY=your-tomtom-key

# CORS allow-list — the deployed web origins (comma-separated). Required in prod
# (unset = no cross-origin). Add each Vercel domain.
CORS_ORIGINS=https://admin.washandgo.app,https://portal.washandgo.app

# Error tracking — optional. Set the DSN from a free Sentry Node project to turn
# on 5xx reporting. Unset = disabled.
# SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzz
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0

# Redis (only when Phase D realtime/jobs lands).
# REDIS_URL=redis://…
