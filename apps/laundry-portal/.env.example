# Laundry (shop) portal (Next.js). Only NEXT_PUBLIC_* — client-bundle vars,
# nothing secret. Firebase web config is committed (public by design).

# API base URL. REQUIRED in production — unset silently falls back to localhost.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Dev-only auth stub (x-dev-uid, needs API AUTH_DEV_BYPASS=1). Defaults to
# "dev-shop" in dev. MUST be unset in production (real Firebase login required).
# NEXT_PUBLIC_DEV_UID=dev-shop
