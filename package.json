{
  "name": "wash-and-go",
  "private": true,
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev:landing": "pnpm --filter wash-and-go-landing-page dev",
    "dev:api": "pnpm --filter @wash-and-go/api start:dev",
    "dev:portal": "pnpm --filter @wash-and-go/laundry-portal dev",
    "build": "pnpm -r build",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "@prisma/client",
      "prisma",
      "@prisma/engines"
    ]
  }
}
